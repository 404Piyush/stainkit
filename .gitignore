*.swp
*.swo
*~
.DS_Store

# Data (large datasets downloaded at runtime)
data/raw/*.svs
data/raw/*.tiff
data/raw/*.tif
data/raw/*.ndpi
data/raw/*.mrxs
data/raw/*.vms
data/raw/*.scn
data/processed/*.png
data/processed/*.jpg
data/processed/*.tiff
data/processed/*.tif
data/benchmark/*.csv
data/benchmark/*.png
data/benchmark/*.json

# Keep directory structure
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/benchmark/.gitkeep

# Logs
*.log
logs/

# OS-specific
Thumbs.db
desktop.ini

# Secrets (never commit tokens)
.env
.env.local
secrets/
*.token
*.pat
