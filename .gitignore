build/
build-*/
out/
cmake-build-*/

# Binaries
*.exe
*.out
*.app
*.so
*.dylib
*.dll
*.o
*.obj
*.a
*.lib
*.exp
*.pdb

# CUDA intermediates
*.cu.o
*.cubin
*.fatbin
*.fatbin.c
*.ptx

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt
CTestTestfile.cmake
_deps/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/
*.whl

# Virtual envs
venv/
env/
.env/
.venv/

# IDEs and editors
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Data (large datasets downloaded at runtime)
# Raw input: whole-slide images can be multi-GB; never commit them.
data/raw/*.svs
data/raw/*.tiff
data/raw/*.tif
data/raw/*.ndpi
data/raw/*.mrxs
data/raw/*.vms
data/raw/*.scn
# Processed outputs: per-image PNGs are kept in docs/screenshots/ for
# the README. The raw processed/ tree is intentionally ignored so the
# repo doesn't fill up with thousands of panel PNGs.
data/processed/*.png
data/processed/*.jpg
data/processed/*.tiff
data/processed/*.tif
# Benchmark CSVs and PNGs are small (a few KB) and useful as proof of
# execution - track them in the repo. Larger benchmark plots live in
# docs/screenshots/ instead.
!data/benchmark/*.csv
data/benchmark/*.png
data/benchmark/*.json

# Keep directory structure
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/benchmark/.gitkeep

# Logs (sample_run_256.log under data/benchmark/ IS tracked - it's
# a proof-of-execution artifact; other *.log files like
# CMakeFiles/*/cmake_output.log are not).
*.log
logs/
!data/benchmark/*.log

# OS-specific
Thumbs.db
desktop.ini

# Secrets (never commit tokens)
.env
.env.local
secrets/
*.token
*.pat
